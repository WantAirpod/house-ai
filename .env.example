HOME_DECISION_AI_ENV=development
HOME_DECISION_AI_CONFIG_DIR=config
HOME_DECISION_AI_APP_NAME=home-decision-ai

# Railway Postgres가 제공하는 DATABASE_URL을 사용합니다.
# 로컬에서는 예: postgresql+psycopg://postgres:postgres@localhost:5432/home_decision_ai
DATABASE_URL=

# Notion 자동 게시용입니다. Integration token은 절대 git에 커밋하지 마세요.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_WATCHLIST_DATABASE_ID=
NOTION_TOP5_DATABASE_ID=
NOTION_EVENTS_DATABASE_ID=
NOTION_PRICE_QUEUE_DATABASE_ID=
NOTION_DAILY_DATABASE_ID=
NOTION_WEEKLY_DATABASE_ID=
NOTION_ALERT_DATABASE_ID=

# LLM 리포트 생성용입니다.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 국토교통부 실거래가 공공데이터 API에 사용합니다.
# PUBLIC_DATA_API_KEY=

# 한국은행 ECOS API에 사용합니다.
# BOK_ECOS_API_KEY=
